---
import BaseLayout from '../layouts/BaseLayout.astro';
import Sidebar from '../components/Sidebar.astro';
import CatalogFilters from '../components/CatalogFilters.astro';
import GameCard from '../components/GameCard.astro';
import { getStats, getTotalPaidPrice, getUniqueValues, readGames } from '../lib/local-games';

const games = await readGames();
const estados = getUniqueValues(games, 'estado');
const launchers = getUniqueValues(games, 'launcher');
const plataformas = getUniqueValues(games, 'plataforma');
const stats = getStats(games);

const drawerEstadosOrdered = [
  'Jugando', 'Terminado', 'Pendiente', 'Wishlist',
  'Pausado', 'Abandonado', 'Retirado', 'Recurrente',
];
const estadosSet = new Set(estados.map((e) => e.toLowerCase()));
const knownEstadoValues = new Set(drawerEstadosOrdered.map((d) => d.toLowerCase()));
const orderedDrawerEstados = [
  ...drawerEstadosOrdered.filter((d) => estadosSet.has(d.toLowerCase()) || d === 'Wishlist'),
  ...estados.filter((e) => !knownEstadoValues.has(e.toLowerCase())),
];

const activeGames = games.filter((g) => String(g.estado ?? '').trim().toLowerCase() === 'jugando').length;
const completedGames = games.filter((g) => {
  const s = String(g.estado ?? '').trim().toLowerCase();
  return s === 'terminado' || s === 'completado';
}).length;
const totalLibraryValue = games.reduce((sum, g) => {
  const base = getTotalPaidPrice(g) ?? 0;
  const microtransacciones = Number(g.gasto_microtransacciones ?? 0);
  const dlc = Array.isArray(g.dlcs?.items)
    ? g.dlcs.items.reduce((acc, d) => acc + Number(d.precio_pagado ?? 0), 0)
    : 0;
  return (
    sum +
    (Number.isNaN(base) ? 0 : base) +
    (Number.isNaN(microtransacciones) ? 0 : microtransacciones) +
    dlc
  );
}, 0);
const formatMoney = (value: number) =>
  new Intl.NumberFormat('es-ES', { style: 'currency', currency: 'EUR', maximumFractionDigits: 0 }).format(value);
---

<BaseLayout title='Personal Database'>
  <main class='shell shell-app shell-desktop-app'>

    <Sidebar
      orderedDrawerEstados={orderedDrawerEstados}
      plataformas={plataformas}
      launchers={launchers}
    />

    <div class='desktop-main'>
      <!-- Hero / Stats -->
      <section class='app-home-grid pc-home-grid'>
        <section class='hero hero-app panel panel-hero pc-hero-card mock-catalog-hero'>

          <div class='mobile-topbar' aria-label='Barra superior movil'>
            <button class='mobile-menu-button' id='mobile-drawer-open' type='button' aria-label='Abrir menu'>
              <svg viewBox='0 0 24 24' aria-hidden='true'><path d='M4 6h16M4 12h16M4 18h16'></path></svg>
            </button>
            <div class='mobile-topbar-brand'>
              <span class='mobile-topbar-mark' aria-hidden='true' style='display:none'>
                <svg viewBox='0 0 640 640' fill='currentColor'>
                  <path d='M448 128C554 128 640 214 640 320C640 426 554 512 448 512L192 512C86 512 0 426 0 320C0 214 86 128 192 128L448 128zM192 240C178.7 240 168 250.7 168 264L168 296L136 296C122.7 296 112 306.7 112 320C112 333.3 122.7 344 136 344L168 344L168 376C168 389.3 178.7 400 192 400C205.3 400 216 389.3 216 376L216 344L248 344C261.3 344 272 333.3 272 320C272 306.7 261.3 296 248 296L216 296L216 264C216 250.7 205.3 240 192 240zM432 336C414.3 336 400 350.3 400 368C400 385.7 414.3 400 432 400C449.7 400 464 385.7 464 368C464 350.3 449.7 336 432 336zM496 240C478.3 240 464 254.3 464 272C464 289.7 478.3 304 496 304C513.7 304 528 289.7 528 272C528 254.3 513.7 240 496 240z'></path>
                </svg>
              </span>
              <div>
                <span class='mobile-topbar-name'>Catálogo</span>
                <span class='mobile-topbar-sub' id='mobile-topbar-sub'>{stats.total} juegos</span>
              </div>
            </div>
            <div class='mobile-topbar-actions'>
              <button class='mobile-topbar-btn' id='mobile-search-toggle' type='button' aria-label='Buscar'>
                <svg viewBox='0 0 24 24' aria-hidden='true'>
                  <circle cx='11' cy='11' r='7'></circle>
                  <path d='m20 20-3.5-3.5'></path>
                </svg>
              </button>
            </div>
          </div>

          <div class='mobile-tab-bar' id='mobile-tab-bar' role='tablist' aria-label='Filtros rápidos'>
            <button class='mobile-tab' type='button' data-quick-filter='' role='tab' aria-pressed='true'>Todos</button>
            <button class='mobile-tab' type='button' data-quick-filter='jugando' role='tab' aria-pressed='false'>
              <span class='mobile-tab-dot' style='background:#6ee76c' aria-hidden='true'></span>Jugando
            </button>
            <button class='mobile-tab' type='button' data-quick-filter='terminado' role='tab' aria-pressed='false'>
              <span class='mobile-tab-dot' style='background:#67b1ff' aria-hidden='true'></span>Terminado
            </button>
            <button class='mobile-tab' type='button' data-quick-filter='wishlist' role='tab' aria-pressed='false'>
              <span class='mobile-tab-dot' style='background:#5ad0ff' aria-hidden='true'></span>Wishlist
            </button>
          </div>

          <div class='app-topline'>
            <div class='app-brand'>
              <div><div class='eyebrow'>Personal Database</div></div>
            </div>
          </div>
          <div class='pc-hero-copy'><h1>Catalogo personal</h1></div>

          <section class='stats stats-bento pc-stats-bento' aria-label='Resumen'>
            <article class='stat'>
              <span class='pc-stat-icon' aria-hidden='true'>
                <svg class='icon-solid' viewBox='0 0 640 640' style='color:#eef3f8;fill:currentColor'>
                  <path fill='currentColor' d='M448 128C554 128 640 214 640 320C640 426 554 512 448 512L192 512C86 512 0 426 0 320C0 214 86 128 192 128L448 128zM192 240C178.7 240 168 250.7 168 264L168 296L136 296C122.7 296 112 306.7 112 320C112 333.3 122.7 344 136 344L168 344L168 376C168 389.3 178.7 400 192 400C205.3 400 216 389.3 216 376L216 344L248 344C261.3 344 272 333.3 272 320C272 306.7 261.3 296 248 296L216 296L216 264C216 250.7 205.3 240 192 240zM432 336C414.3 336 400 350.3 400 368C400 385.7 414.3 400 432 400C449.7 400 464 385.7 464 368C464 350.3 449.7 336 432 336zM496 240C478.3 240 464 254.3 464 272C464 289.7 478.3 304 496 304C513.7 304 528 289.7 528 272C528 254.3 513.7 240 496 240z'></path>
                </svg>
              </span>
              <div class='pc-stat-copy'>
                <strong data-stat-total>{stats.total}</strong>
                <span class='muted'>juegos</span>
              </div>
            </article>
            <article class='stat'>
              <span class='pc-stat-icon' aria-hidden='true'>
                <svg class='icon-solid' viewBox='0 0 640 640' style='color:#eef3f8;fill:currentColor'>
                  <path fill='currentColor' d='M320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320C64 178.6 178.6 64 320 64zM296 184L296 320C296 328 300 335.5 306.7 340L402.7 404C413.7 411.4 428.6 408.4 436 397.3C443.4 386.2 440.4 371.4 429.3 364L344 307.2L344 184C344 170.7 333.3 160 320 160C306.7 160 296 170.7 296 184z'></path>
                </svg>
              </span>
              <div class='pc-stat-copy'>
                <strong data-stat-hours>{stats.horas}</strong>
                <span class='muted'>h</span>
              </div>
            </article>
            <article class='stat'>
              <span class='pc-stat-icon' aria-hidden='true'>
                <svg class='icon-solid' viewBox='0 0 640 640' style='color:#eef3f8;fill:currentColor'>
                  <path fill='currentColor' d='M128 96C92.7 96 64 124.7 64 160L64 448C64 483.3 92.7 512 128 512L512 512C547.3 512 576 483.3 576 448L576 256C576 220.7 547.3 192 512 192L136 192C122.7 192 112 181.3 112 168C112 154.7 122.7 144 136 144L520 144C533.3 144 544 133.3 544 120C544 106.7 533.3 96 520 96L128 96zM480 320C497.7 320 512 334.3 512 352C512 369.7 497.7 384 480 384C462.3 384 448 369.7 448 352C448 334.3 462.3 320 480 320z'></path>
                </svg>
              </span>
              <div class='pc-stat-copy'>
                <strong>{formatMoney(totalLibraryValue)}</strong>
                <span class='muted'>valor</span>
              </div>
            </article>
            <article class='stat stat-accent'>
              <span class='pc-stat-icon' aria-hidden='true'>
                <svg class='icon-solid' viewBox='0 0 640 640' style='color:#eef3f8;fill:currentColor'>
                  <path fill='currentColor' d='M64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576C178.6 576 64 461.4 64 320zM252.3 211.1C244.7 215.3 240 223.4 240 232L240 408C240 416.7 244.7 424.7 252.3 428.9C259.9 433.1 269.1 433 276.6 428.4L420.6 340.4C427.7 336 432.1 328.3 432.1 319.9C432.1 311.5 427.7 303.8 420.6 299.4L276.6 211.4C269.2 206.9 259.9 206.7 252.3 210.9z'></path>
                </svg>
              </span>
              <div class='pc-stat-copy'>
                <strong>{activeGames}</strong>
                <span class='muted'>activos</span>
              </div>
            </article>
            <article class='stat stat-accent-alt'>
              <span class='pc-stat-icon' aria-hidden='true'>
                <svg class='icon-solid' viewBox='0 0 640 640' style='color:#eef3f8;fill:currentColor'>
                  <path fill='currentColor' d='M320 576C178.6 576 64 461.4 64 320C64 178.6 178.6 64 320 64C461.4 64 576 178.6 576 320C576 461.4 461.4 576 320 576zM438 209.7C427.3 201.9 412.3 204.3 404.5 215L285.1 379.2L233 327.1C223.6 317.7 208.4 317.7 199.1 327.1C189.8 336.5 189.7 351.7 199.1 361L271.1 433C276.1 438 282.9 440.5 289.9 440C296.9 439.5 303.3 435.9 307.4 430.2L443.3 243.2C451.1 232.5 448.7 217.5 438 209.7z'></path>
                </svg>
              </span>
              <div class='pc-stat-copy'>
                <strong data-stat-finished>{completedGames}</strong>
                <span class='muted'>completados</span>
              </div>
            </article>
          </section>

        </section>
      </section>

      <!-- Filtros del catálogo -->
      <CatalogFilters
        estados={estados}
        launchers={launchers}
        plataformas={plataformas}
        totalGames={stats.total}
      />

      <!-- Grid de cards -->
      <section class='mock-catalog-results panel'>
        <section class='cards cards-bento mock-cards-grid' id='cards'></section>
      </section>

      <!-- Vista tabla -->
      <section class='inventory-table-shell' id='table-shell' hidden>
        <div class='inventory-table'>
          <div class='inventory-table-head'>
            <span>Juego</span>
            <span>Estado</span>
            <span>Launcher</span>
            <span>Plataforma</span>
            <span>Horas</span>
            <span>Pagado</span>
            <span>Lanzamiento</span>
            <span class='inventory-table-actions-head'></span>
          </div>
          <div class='inventory-table-body' id='table-body'></div>
        </div>
      </section>

    </div><!-- /desktop-main -->

    <!-- Templates y dialog -->
    <GameCard />

  </main>

  <!-- Puente de datos: serializa games para catalog.ts -->
  <div id='__catalog-data' data-games={JSON.stringify(games)} hidden></div>

  <script>
    import { initCatalog } from '../scripts/catalog';
    const dataEl = document.getElementById('__catalog-data');
    const games = JSON.parse(dataEl?.dataset.games ?? '[]');
    initCatalog(games);
  </script>
</BaseLayout>
