---
/**
 * GameDetailComments.astro — Sección de comentarios libres del juego.
 * Muestra el campo de texto libre 'comentarios'. Se oculta visualmente
 * si no hay comentarios (clase detail-comments-empty).
 * Datos: comentarios viene del campo game.comentarios formateado en [slug].astro.
 */
import '../../styles/game-detail/comments.css';
import '../../styles/game-detail/edit.css';

interface CommentsEditValues {
  comentarios: string | null;
}

interface Props {
  slug: string;
  comentarios: string;
  editValues: CommentsEditValues;
}

const { slug, comentarios, editValues } = Astro.props;
---

<section
  class:list={[
    "detail-comments",
    "detail-comments-vault",
    comentarios === "-" && "detail-comments-empty",
  ]}
>
  <div class="detail-comments-head">
    <div>
      <span class="section-eyebrow">Notas</span>
      <dt class="muted">Comentarios</dt>
    </div>
    <button class="game-edit-trigger game-edit-trigger-sm" id="comments-edit-trigger" type="button" aria-label="Editar comentarios">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 20h9"></path>
        <path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"></path>
      </svg>
    </button>
  </div>
  <dd>{comentarios}</dd>
</section>

<dialog class="edit-dialog" id="comments-edit-dialog">
  <div class="edit-dialog-body">
    <div class="edit-dialog-head">
      <div>
        <h2>Editar Comentarios</h2>
        <p class="edit-dialog-sub">Escribe directo en games.json. Solo funciona en local (npm run dev).</p>
      </div>
      <button class="edit-dialog-close" id="comments-edit-close" type="button" aria-label="Cerrar">×</button>
    </div>

    <p class="edit-dialog-error" id="comments-edit-error" hidden></p>

    <form id="comments-edit-form" data-slug={slug}>
      <div class="edit-field">
        <label for="comments-edit-textarea">Comentarios</label>
        <textarea id="comments-edit-textarea" name="comentarios" rows="6">{editValues.comentarios ?? ''}</textarea>
      </div>

      <div class="edit-dialog-actions">
        <button class="edit-dialog-cancel" id="comments-edit-cancel" type="button">Cancelar</button>
        <button class="edit-dialog-submit" id="comments-edit-submit" type="submit">Guardar cambios</button>
      </div>
    </form>
  </div>
</dialog>

<script>
  const trigger = document.getElementById('comments-edit-trigger');
  const dialog = document.getElementById('comments-edit-dialog');
  const form = document.getElementById('comments-edit-form');
  const closeBtn = document.getElementById('comments-edit-close');
  const cancelBtn = document.getElementById('comments-edit-cancel');
  const errorBox = document.getElementById('comments-edit-error');
  const submitBtn = document.getElementById('comments-edit-submit');

  if (
    trigger instanceof HTMLButtonElement &&
    dialog instanceof HTMLDialogElement &&
    form instanceof HTMLFormElement &&
    errorBox instanceof HTMLElement &&
    submitBtn instanceof HTMLButtonElement
  ) {
    const hideError = () => errorBox.setAttribute('hidden', '');
    const showError = (message: string) => {
      errorBox.textContent = message;
      errorBox.removeAttribute('hidden');
    };

    trigger.addEventListener('click', () => {
      hideError();
      dialog.showModal();
    });

    closeBtn?.addEventListener('click', () => dialog.close());
    cancelBtn?.addEventListener('click', () => dialog.close());

    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) dialog.close();
    });

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      hideError();

      const slug = form.dataset.slug ?? '';
      const data = new FormData(form);
      const payload = {
        comentarios: data.get('comentarios'),
      };

      submitBtn.disabled = true;
      submitBtn.textContent = 'Guardando…';

      try {
        const response = await fetch(`/api/games/${slug}/edit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !result.ok) {
          throw new Error(result.error || `No se pudo guardar (HTTP ${response.status}).`);
        }
        window.location.reload();
      } catch (error) {
        showError(error instanceof Error ? error.message : 'No se pudo guardar.');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Guardar cambios';
      }
    });
  }
</script>
