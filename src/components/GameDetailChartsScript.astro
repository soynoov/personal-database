<script>
  import { Chart, Filler, Tooltip, CategoryScale, LinearScale, LineController, LineElement, PointElement } from "chart.js";

  Chart.register(Filler, Tooltip, CategoryScale, LinearScale, LineController, LineElement, PointElement);

  const charts = new Map();

  const formatMetricValue = (metric, value) => {
    if (metric === "currency") return `${Number(value).toFixed(2)} EUR`;
    return `${Number(value).toFixed(1)} h`;
  };

  const buildGradient = (ctx, area, colorStops) => {
    const gradient = ctx.createLinearGradient(0, area.top, 0, area.bottom);
    colorStops.forEach(([stop, color]) => gradient.addColorStop(stop, color));
    return gradient;
  };

  const readChartPayload = (canvasId) => {
    const canvas = document.getElementById(canvasId);
    if (!(canvas instanceof HTMLCanvasElement)) return null;

    try {
      return {
        canvas,
        payload: JSON.parse(canvas.dataset.chart ?? "null"),
      };
    } catch {
      return null;
    }
  };

  const renderLineChart = (canvasId, palette) => {
    const chartData = readChartPayload(canvasId);
    if (!chartData) return;

    const { canvas, payload } = chartData;
    const labels = Array.isArray(payload?.points) ? payload.points.map((point) => point.label) : [];
    const values = Array.isArray(payload?.points) ? payload.points.map((point) => Number(point.value)) : [];
    if (labels.length < 2 || values.some((value) => Number.isNaN(value))) return;

    charts.get(canvasId)?.destroy();

    const chart = new Chart(canvas, {
      type: "line",
      data: {
        labels,
        datasets: [
          {
            label: payload.seriesLabel,
            data: values,
            fill: true,
            tension: 0.34,
            borderWidth: 2,
            borderColor: palette.stroke,
            pointRadius: 3,
            pointHoverRadius: 5,
            pointBackgroundColor: palette.stroke,
            pointBorderWidth: 0,
            backgroundColor(context) {
              const { chart } = context;
              const { ctx, chartArea } = chart;
              if (!chartArea) return palette.fillFallback;
              return buildGradient(ctx, chartArea, palette.fill);
            },
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          intersect: false,
          mode: "index",
        },
        plugins: {
          legend: {
            display: false,
          },
          tooltip: {
            displayColors: false,
            backgroundColor: "rgba(13, 18, 26, 0.94)",
            borderColor: "rgba(255, 255, 255, 0.1)",
            borderWidth: 1,
            padding: 12,
            titleColor: "#f7f1ee",
            bodyColor: "#dbe4ef",
            callbacks: {
              label(context) {
                return formatMetricValue(payload.metric, context.parsed.y);
              },
            },
          },
        },
        scales: {
          x: {
            border: {
              display: false,
            },
            grid: {
              display: false,
            },
            ticks: {
              color: "rgba(218, 226, 236, 0.62)",
              font: {
                size: 11,
              },
            },
          },
          y: {
            border: {
              display: false,
            },
            grid: {
              color: "rgba(132, 146, 166, 0.16)",
              drawTicks: false,
            },
            ticks: {
              color: "rgba(218, 226, 236, 0.5)",
              padding: 10,
              font: {
                size: 11,
              },
              callback(value) {
                return formatMetricValue(payload.metric, value);
              },
            },
          },
        },
      },
    });

    charts.set(canvasId, chart);
  };

  const renderAllCharts = () => {
    renderLineChart("hours-detail-chart", {
      stroke: "#c56cff",
      fillFallback: "rgba(197, 108, 255, 0.18)",
      fill: [
        [0, "rgba(197, 108, 255, 0.32)"],
        [1, "rgba(197, 108, 255, 0.03)"],
      ],
    });

    renderLineChart("money-detail-chart", {
      stroke: "#9bff83",
      fillFallback: "rgba(155, 255, 131, 0.18)",
      fill: [
        [0, "rgba(155, 255, 131, 0.26)"],
        [1, "rgba(155, 255, 131, 0.03)"],
      ],
    });
  };

  renderAllCharts();
  window.addEventListener("resize", renderAllCharts);
</script>
