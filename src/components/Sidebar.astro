---
import { normalizeStatus } from '../lib/game-status';

interface Props {
  orderedDrawerEstados: string[];
  plataformas: string[];
  launchers: string[];
  active?: 'catalogo' | 'estadisticas' | 'criticas';
}

const { orderedDrawerEstados, plataformas, launchers, active = 'catalogo' } = Astro.props;

const estadoColor = (estado: string): string => {
  const n = normalizeStatus(estado);
  if (n === 'jugando') return '#6ee76c';
  if (n === 'terminado' || n === 'completado') return '#67b1ff';
  if (n === 'pendiente') return '#f5c518';
  if (n === 'wishlist') return '#5ad0ff';
  if (n === 'pausado') return '#f5a818';
  if (n === 'abandonado' || n === 'retirado') return '#ff7055';
  if (n === 'recurrente') return '#c9a0ff';
  return '#8b9ab5';
};
---

<!-- Mobile Drawer Overlay -->
<div class='mobile-drawer-overlay' id='mobile-drawer-overlay' aria-hidden='true'></div>

<!-- Mobile Drawer -->
<nav
  class='mobile-drawer'
  id='mobile-drawer'
  aria-label='Menú lateral'
  aria-hidden='true'
>
  <div class='mobile-drawer-header'>
    <div class='mobile-drawer-brand'>
      <div class='desktop-sidebar-brandmark mobile-brandmark' aria-hidden='true'>
        <img src='/logo-mark.png' alt='' loading='eager' decoding='async' />
      </div>
      <div class='mobile-brand-copy'>
        <span>Personal</span>
        <span>Database</span>
      </div>
    </div>
    <button class='mobile-drawer-close' id='mobile-drawer-close' type='button' aria-label='Cerrar menú'>
      <svg viewBox='0 0 24 24' aria-hidden='true'>
        <path d='M18 6 6 18'></path>
        <path d='m6 6 12 12'></path>
      </svg>
    </button>
  </div>

  <div class='mobile-drawer-body'>
    <div class='mobile-drawer-section'>
      <span class='mobile-drawer-section-label'>Estado</span>
      <button class='mobile-drawer-item' data-drawer-filter='estado' data-value='' type='button'>
        <span class='mobile-drawer-dot' style='background:#5a6a80'></span>
        <span>Todos</span>
      </button>
      {orderedDrawerEstados.map((estado) => (
        <button class='mobile-drawer-item' data-drawer-filter='estado' data-value={estado} type='button'>
          <span class='mobile-drawer-dot' style={`background:${estadoColor(estado)}`} />
          <span>{estado}</span>
        </button>
      ))}
    </div>

    {plataformas.length > 0 && (
      <div class='mobile-drawer-section'>
        <span class='mobile-drawer-section-label'>Plataforma</span>
        <button class='mobile-drawer-item' data-drawer-filter='plataforma' data-value='' type='button'>
          <span>Todas</span>
        </button>
        {plataformas.map((p) => (
          <button class='mobile-drawer-item' data-drawer-filter='plataforma' data-value={p} type='button'>
            <span>{p}</span>
          </button>
        ))}
      </div>
    )}

    {launchers.length > 0 && (
      <div class='mobile-drawer-section'>
        <span class='mobile-drawer-section-label'>Launcher</span>
        <button class='mobile-drawer-item' data-drawer-filter='launcher' data-value='' type='button'>
          <span>Todos</span>
        </button>
        {launchers.map((l) => (
          <button class='mobile-drawer-item' data-drawer-filter='launcher' data-value={l} type='button'>
            <span>{l}</span>
          </button>
        ))}
      </div>
    )}

    <div class='mobile-drawer-section mobile-drawer-section-compact'>
      <span class='mobile-drawer-section-label'>Modo de juego</span>
      <button class='mobile-drawer-item' data-drawer-filter='solo' data-value='' type='button'>
        <span>Todos</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='solo' data-value='true' type='button'>
        <span>Solo</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='solo' data-value='false' type='button'>
        <span>Multijugador</span>
      </button>
    </div>

    <div class='mobile-drawer-section mobile-drawer-section-compact'>
      <span class='mobile-drawer-section-label'>Precio pagado</span>
      <button class='mobile-drawer-item' data-drawer-filter='precio' data-value='' type='button'>
        <span>Todos</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='precio' data-value='free' type='button'>
        <span>Free to play</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='precio' data-value='cheap' type='button'>
        <span>Hasta 10 EUR</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='precio' data-value='mid' type='button'>
        <span>De 10 a 30 EUR</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='precio' data-value='high' type='button'>
        <span>Más de 30 EUR</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='precio' data-value='unknown' type='button'>
        <span>Sin dato</span>
      </button>
    </div>

    <div class='mobile-drawer-section'>
      <span class='mobile-drawer-section-label'>Ordenar</span>
      <button class='mobile-drawer-item' data-drawer-filter='sort' data-value='titulo-asc' type='button'>
        <span>A → Z</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='sort' data-value='horas-desc' type='button'>
        <span>Más horas</span>
      </button>
      <button class='mobile-drawer-item' data-drawer-filter='sort' data-value='lanzamiento-desc' type='button'>
        <span>Más reciente</span>
      </button>
    </div>
  </div>
</nav>

